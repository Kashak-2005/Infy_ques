def maxSum(A):
    n = len(A)
    dp = [0] * (n + 1)

    for i in range(n - 1, -1, -1):
        next_index = i + A[i] + 1
        
        dp[i] = max(
            dp[i + 1],
            A[i] + (dp[next_index] if next_index < n else 0)
        )

    return dp[0]


# ---------- main ----------
if __name__ == "__main__":
    n = int(input())
    A = []
    for _ in range(n):
        A.append(int(input()))

    print(maxSum(A))
